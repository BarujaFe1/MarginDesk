# MarginDesk — environment example (no secrets)
# Copy to .env and adjust locally. Never commit real credentials.

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_HOST=127.0.0.1
API_PORT=8000

# Optional future integrations (leave empty for local MVP)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# STRIPE_API_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# RESEND_API_KEY=
